<Window x:Class="WaterFilterCBZ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WaterFilterCBZ"
        mc:Ignorable="d"
        Title="WaterFilterCBZ - Real-Time Sensor Monitor" 
        Height="700" Width="1200"
        Background="#F5F5F5" x:Name="MainWindowControl">

    <Window.Resources>
        <!-- Invert Boolean Converter -->
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <!-- Stale flag visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Top Status Bar -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="10" Height="50">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBlock AutomationProperties.AutomationId="ConnectionStatusText" Text="{Binding ConnectionStatus}" Foreground="#27AE60" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock AutomationProperties.AutomationId="StatusMessageText" Text="{Binding StatusMessage}" Foreground="White" VerticalAlignment="Center" FontSize="12" Margin="0,0,30,0"/>
                <TextBlock Text="Samples:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBlock AutomationProperties.AutomationId="SampleCountText" Text="{Binding SampleCount}" Foreground="#3498DB" VerticalAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Bottom Control Bar -->
        <Border DockPanel.Dock="Bottom" Background="#ECF0F1" Padding="10" Height="60">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Clear Data Button -->
                <Button AutomationProperties.AutomationId="ClearDataButton"
                        Command="{Binding ClearDataCommand}"
                        Content="Clear Data"
                        Padding="15,8" 
                        Background="#E74C3C" 
                        Foreground="White"
                        FontSize="12"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,10,0"/>

                <Button AutomationProperties.AutomationId="OpenLogsButton"
                        Command="{Binding OpenLogsCommand}"
                        Content="Open Logs"
                        Padding="15,8"
                        Background="#3498DB"
                        Foreground="White"
                        FontSize="12"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,0,10,0"/>
                
                <!-- Separator -->
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,10,0"/>
                
                <!-- COM Port Selection -->
                <TextBlock Text="COM Port:" 
                          Foreground="#2C3E50" 
                          VerticalAlignment="Center" 
                          FontWeight="Bold"
                          Margin="0,0,5,0"/>
                
                <ComboBox AutomationProperties.AutomationId="PortSelector"
                         ItemsSource="{Binding AvailablePorts}"
                         SelectedItem="{Binding SelectedPort}"
                         Width="100"
                         Padding="8,5"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsConnected, Converter={StaticResource InvertBoolConverter}}"
                         Margin="0,0,10,0"/>
                
                <!-- Connect Button -->
                <Button AutomationProperties.AutomationId="ConnectButton"
                       Command="{Binding ConnectCommand}"
                       Content="Connect"
                       Padding="15,8" 
                       Background="#27AE60" 
                       Foreground="White"
                       FontSize="12"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Margin="0,0,10,0"/>
                
                <!-- Disconnect Button -->
                <Button AutomationProperties.AutomationId="DisconnectButton"
                       Command="{Binding DisconnectCommand}"
                       Content="Disconnect"
                       Padding="15,8" 
                       Background="#E67E22" 
                       Foreground="White"
                       FontSize="12"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Margin="0,0,20,0"/>
                
                <!-- Info Text -->
                <TextBlock Text="Right-click chart to zoom or pan" 
                          Foreground="#7F8C8D" 
                          VerticalAlignment="Center" 
                          Margin="20,0,0,0" 
                          FontSize="11" 
                          FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- OxyPlot Chart Container -->
            <Grid Grid.Column="0" Background="White" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <oxy:PlotView Model="{Binding PlotModel1}" />
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <oxy:PlotView Model="{Binding PlotModel2}" />
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <oxy:PlotView Model="{Binding PlotModel3}" />
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6">
                    <oxy:PlotView Model="{Binding PlotModel4}" />
                </Border>
            </Grid>

            <!-- Sensor List Panel -->
            <StackPanel Grid.Column="1" Background="White" Margin="0,10,10,10" MinWidth="250">
                <TextBlock Text="Active Sensors" 
                          Background="#34495E" 
                          Foreground="White" 
                          Padding="10,8" 
                          FontSize="14" 
                          FontWeight="Bold"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl AutomationProperties.AutomationId="SensorList" ItemsSource="{Binding Sensors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#BDC3C7" BorderThickness="0,0,0,1" Padding="10,8">
                                    <StackPanel>
                                        <!-- Sensor ID -->
                                        <TextBlock Text="{Binding SensorId, StringFormat='Sensor: {0}'}" 
                                                  FontWeight="Bold" 
                                                  FontSize="12"
                                                  Foreground="#2C3E50"/>

                                        <!-- Current Value (turns red when the reading is stale) -->
                                        <TextBlock Text="{Binding CurrentValue, StringFormat='Value: {0:F2}'}"
                                                  FontSize="11"
                                                  Margin="0,3,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#27AE60"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsStale}" Value="True">
                                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Stale-data indicator (RC-002 / SRS-C-001): visible only when no fresh sample for > 5 s -->
                                        <TextBlock AutomationProperties.AutomationId="SensorStaleIndicator"
                                                  Text="⚠ STALE — no new data &gt; 5 s"
                                                  FontSize="10"
                                                  FontWeight="Bold"
                                                  Foreground="#E74C3C"
                                                  Margin="0,2,0,0"
                                                  Visibility="{Binding IsStale, Converter={StaticResource BoolToVisibility}}"/>

                                        <!-- Stats Grid -->
                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                      Text="{Binding MinValue, StringFormat='Min: {0:F2}'}" 
                                                      FontSize="10"
                                                      Foreground="#95A5A6"/>
                                            <TextBlock Grid.Column="1" 
                                                      Text="{Binding MaxValue, StringFormat='Max: {0:F2}'}" 
                                                      FontSize="10"
                                                      Foreground="#95A5A6"/>
                                        </Grid>

                                        <!-- Average -->
                                        <TextBlock Text="{Binding AvgValue, StringFormat='Avg: {0:F2}'}" 
                                                  FontSize="10"
                                                  Foreground="#95A5A6"
                                                  Margin="0,2,0,0"/>

                                        <!-- Reading Count -->
                                        <TextBlock Text="{Binding ReadingCount, StringFormat='Readings: {0}'}" 
                                                  FontSize="9"
                                                  Foreground="#BDC3C7"
                                                  Margin="0,2,0,0"/>

                                        <!-- Last Update -->
                                        <TextBlock Text="{Binding LastUpdate, StringFormat='Updated: {0:HH:mm:ss}'}" 
                                                  FontSize="9"
                                                  Foreground="#BDC3C7"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
